# The shipped Studio needs NO environment variables — it runs fully client-side
# on bundled seed data. These are only for the OPTIONAL live-API upgrade (Roadmap R1/R2):
#
# Base URL of a live persistence/adapter API. When set, the adapters in
# src/adapters/ can be pointed here instead of src/seed/* with no module changes.
# VITE_API_BASE_URL=https://your-api.example.run.app
#
# Optional live LLM assist for Product Discovery (Roadmap R5); templates are used when absent.
# VITE_LLM_ASSIST=false
